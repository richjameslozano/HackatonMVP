# Lark verification token for webhook validation
LARK_VERIFICATION_TOKEN=your_verification_token_here

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Maximum number of concurrent WebSocket connections
MAX_CONNECTIONS=50

# ─── Lark API Credentials ───────────────────────────────────────────────────
LARK_APP_ID=your_lark_app_id_here
LARK_APP_SECRET=your_lark_app_secret_here
LARK_BASE_APP_TOKEN=your_lark_base_app_token_here
LARK_BASE_URL=https://open.larksuite.com/open-apis

# ─── Table Configuration ────────────────────────────────────────────────────
# Comma-separated list of Lark Base table IDs to cache
CONFIGURED_TABLES=table_id_1,table_id_2

# ─── Frontend Auth ──────────────────────────────────────────────────────────
# Shared secret for service-to-service authentication between frontend and backend
API_SHARED_SECRET=your_shared_secret_here

# ─── Cache & Write Queue Configuration ─────────────────────────────────────
# Time-to-live for cached records in seconds (1–86400)
CACHE_TTL_SECONDS=300
# Interval between batch flush cycles in seconds (1–86400)
BATCH_FLUSH_INTERVAL_SECONDS=10
