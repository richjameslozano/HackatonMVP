# Lark Open Platform App ID (from Lark Developer Console)
VITE_LARK_APP_ID=your_app_id_here

# Lark Open Platform App Secret (from Lark Developer Console)
VITE_LARK_APP_SECRET=your_app_secret_here

# Lark Base (Bitable) App Token (from your Lark Base URL)
VITE_LARK_APP_TOKEN=your_app_token_here

# OAuth redirect URI (must match the one configured in Lark Developer Console)
VITE_LARK_REDIRECT_URI=http://localhost:5173/auth/callback

# WebSocket URL for real-time updates from the backend
VITE_WS_URL=ws://localhost:8000/ws

# Shared secret for authenticating frontend requests to the backend API
VITE_API_SHARED_SECRET=your-shared-secret-here

# Backend API base URL
VITE_BACKEND_URL=http://localhost:8000
