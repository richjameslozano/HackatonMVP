# Backend API base URL
VITE_BACKEND_URL=https://hackatonmvp-backend.onrender.com

# WebSocket URL for real-time updates from the backend
VITE_WS_URL=wss://hackatonmvp-backend.onrender.com/ws

# Lark Open Platform App ID (from Lark Developer Console)
VITE_LARK_APP_ID=cli_xxx

# Lark Base (Bitable) App Token (from your Lark Base URL)
VITE_LARK_APP_TOKEN=bascn_xxx

# OAuth redirect URI (must match the one configured in Lark Developer Console)
VITE_LARK_REDIRECT_URI=https://hackatonmvp-frontend.onrender.com/auth/callback

# Shared secret for authenticating frontend requests to the backend API
VITE_API_SHARED_SECRET=your-shared-secret

# NOTE: VITE_LARK_APP_SECRET is intentionally NOT included here.
# The Lark app secret must only live on the backend as LARK_APP_SECRET.
